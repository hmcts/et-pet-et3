[
  {
    "label": "test $ZED_RELATIVE_FILE:$ZED_ROW",
    "command": "ruby",
    "args": ["-S", "rspec", "$ZED_RELATIVE_FILE:$ZED_ROW"],
    "env": {
      "BUNDLE_GEMFILE": "$ZED_WORKTREE_ROOT/Gemfile",
      "RUBYOPT": "-rbundler/setup",
    },
    "cwd": "$ZED_WORKTREE_ROOT",
    "tags": ["ruby-test"],
  },
  {
    "label": "Debug env",
    "command": "env",
    "args": [],
    "cwd": "$ZED_WORKTREE_ROOT",
  },
]
